{
    "name": "shaunsocial/core",
    "type": "project",
    "description": "ShaunSocial core",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.2",
        "intervention/image": "^3.2",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.10.1",
        "league/flysystem-aws-s3-v3": "^3.0",
        "php-ffmpeg/php-ffmpeg": "^1.1",
        "predis/predis": "^2.1",
        "pusher/pusher-php-server": "^7.2",
        "phpseclib/phpseclib": "^3.0",
        "srmklive/paypal": "^3.0",
        "aporat/store-receipt-validator": "^4.0",
        "jdavidbakr/laravel-cache-garbage-collector": "^2.0",
        "kreait/laravel-firebase": "^6.0",
        "twilio/sdk": "8",
        "giggsey/libphonenumber-for-php": "*",
        "pragmarx/google2fa": "^8.0",
        "bacon/bacon-qr-code": "^3.0",
        "laravel/reverb": "^1.5",
        "razorpay/razorpay": "^2.9",
        "readdle/app-store-server-api": "^3.15.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.7",
        "barryvdh/laravel-ide-helper": "^3.6",
        "fakerphp/faker": "^1.23",
        "kkomelin/laravel-translatable-string-exporter": "^1.17",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.6",
        "spatie/laravel-ignition": "^2.0",
        "stripe/stripe-php": "^16.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
			"Packages\\ShaunSocial\\Core\\": "packages/shaunsocial/core/src/",
            "Packages\\ShaunSocial\\Chat\\": "packages/shaunsocial/chat/src/",
            "Packages\\ShaunSocial\\Story\\": "packages/shaunsocial/story/src/",
            "Packages\\ShaunSocial\\UserVerify\\": "packages/shaunsocial/user_verify/src/",
            "Packages\\ShaunSocial\\Wallet\\": "packages/shaunsocial/wallet/src/",
            "Packages\\ShaunSocial\\Gateway\\": "packages/shaunsocial/gateway/src/",
            "Packages\\ShaunSocial\\GatewayRecurring\\": "packages/shaunsocial/gateway_recurring/src/",
            "Packages\\ShaunSocial\\UserPage\\": "packages/shaunsocial/user_page/src/",
            "Packages\\ShaunSocial\\Advertising\\": "packages/shaunsocial/advertising/src/",
            "Packages\\ShaunSocial\\UserSubscription\\": "packages/shaunsocial/user_subscription/src/",
            "Packages\\ShaunSocial\\Group\\": "packages/shaunsocial/group/src/",
            "Packages\\ShaunSocial\\Vibb\\": "packages/shaunsocial/vibb/src/",
            "Packages\\ShaunSocial\\PaidContent\\": "packages/shaunsocial/paid_content/src/",
            "Packages\\ShaunSocial\\AiFeatures\\": "packages/shaunsocial/ai_features/src/",
            "Packages\\ShaunSocial\\Chatbot\\": "packages/shaunsocial/chatbot/src/",
            "Packages\\ShaunSocial\\AiProvider\\": "packages/shaunsocial/ai_provider/src/",
            "Packages\\ShaunSocial\\Dating\\": "packages/shaunsocial/dating/src/",
            "Packages\\ShaunSocial\\Gift\\": "packages/shaunsocial/gift/src/",
            "Packages\\ShaunSocial\\MigrateOldDating\\": "packages/shaunsocial/migrate_old_dating/src/",
            "Packages\\ShaunSocial\\AiChatProfiles\\": "packages/shaunsocial/ai_chat_profiles/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-install-cmd": [
            "Google_Task_Composer::cleanup"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "Google_Task_Composer::cleanup"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "google/apiclient-services": [
            "AndroidPublisher"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
